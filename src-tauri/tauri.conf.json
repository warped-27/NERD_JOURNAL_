{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NERD_JOURNAL_",
  "version": "0.1.0",
  "identifier": "com.nerdjournal.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:8081",
    "beforeDevCommand": "npm run web:tauri",
    "beforeBuildCommand": "npm run export:web"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "NERD_JOURNAL_",
        "width": 1280,
        "height": 860,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self' blob: data:; script-src 'self' 'wasm-unsafe-eval'; connect-src 'self' https://generativelanguage.googleapis.com http://localhost:* http://127.0.0.1:* https:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity"
  }
}
